# Telegram Bot Token (získaš od @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# TELEGRAM_CHAT_ID už nepotrebuješ – každý user je identifikovaný automaticky

# Globálny rozsah scrapingu (čo najširší – filtruje sa per-user)
GLOBAL_MIN_PRICE=1000000
GLOBAL_MAX_PRICE=20000000
GLOBAL_ROOMS=1+kk,1+1,2+kk,2+1,3+kk,3+1,4+kk,4+1

# Interval kontroly v minútach
CHECK_INTERVAL_MINUTES=10

# Cesta k databáze
DB_PATH=data/listings.db
